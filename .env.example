# Voxely Environment Configuration
# Copy this file to .env and fill in the values

# ===== SECURITY =====
# Secret key for JWT token generation (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# Root password for API authentication (should be strong)
ROOT_PASSWORD=change-me-in-production

# ===== CORS =====
# Frontend URL for CORS configuration (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# ===== API =====
# Backend API host and port
API_HOST=0.0.0.0
API_PORT=25401

# ===== FRONTEND =====
# API URL for frontend (only needed if different from default)
NEXT_PUBLIC_API_URL=http://localhost:25401/api/v1

# ===== ENVIRONMENT =====
# Set to 'production', 'staging', or 'development'
ENVIRONMENT=development

# ===== OPTIONAL: Error Tracking =====
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# ===== OPTIONAL: Logging =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# the base Path for the Voxely
BASE_PATH=/home/user/Voxely

# Nginx Host port
HOST_PORT_HTTP=80